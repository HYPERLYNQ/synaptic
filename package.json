{
  "name": "@hyperlynq/synaptic",
  "version": "1.7.0",
  "description": "Persistent local memory for Claude Code — cross-session context recall, semantic search, zero cloud",
  "type": "module",
  "main": "build/src/index.js",
  "bin": {
    "synaptic": "build/src/cli.js"
  },
  "files": [
    "build/src/",
    "build/scripts/rebuild-index.js",
    "build/scripts/rebuild-index.d.ts",
    ".claude-plugin/",
    "commands/",
    ".mcp.json",
    "scripts/prune-onnxruntime-binaries.cjs",
    "scripts/migrate-v1.5.0.cjs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "migrate:v1.5.0": "node scripts/migrate-v1.5.0.cjs",
    "rebuild-index": "node build/scripts/rebuild-index.js",
    "smoke-test": "npm run build && node build/scripts/smoke-test.js",
    "smoke:v1.5.0": "npm run build && node build/scripts/smoke-v1.5.0.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:search": "npm run build && node build/scripts/test-search.js",
    "test:cleanup": "npm run build && node build/scripts/test-cleanup.js",
    "test:all": "vitest run && npm run build && node build/scripts/smoke-test.js && node build/scripts/test-search.js && node build/scripts/test-cleanup.js",
    "prepublishOnly": "npm run build && node scripts/sync-plugin-version.cjs"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "memory",
    "context",
    "persistent-memory",
    "model-context-protocol",
    "ai-tools",
    "developer-tools"
  ],
  "author": "HYPERLYNQ <hyperlynq@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HYPERLYNQ/synaptic.git"
  },
  "homepage": "https://github.com/HYPERLYNQ/synaptic",
  "bugs": {
    "url": "https://github.com/HYPERLYNQ/synaptic/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "sqlite-vec": "^0.1.7-alpha.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
